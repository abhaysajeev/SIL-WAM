# Copy to .env.prod and fill in real values before deploying
# Generate SECRET_KEY: openssl rand -hex 32

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=silwam
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sil_wam
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_run_openssl_rand_-hex_32
DEBUG=False

# ── Meta / WhatsApp ─────────────────────────────────────────────────────────
FB_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=

# ── Optional Redis (for wamid dedup fast path) ───────────────────────────────
# Leave empty to rely on DB unique index only
REDIS_URL=
